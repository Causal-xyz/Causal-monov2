# Deployed contract addresses (Fuji - deployed 2026-03-10)
NEXT_PUBLIC_MOCK_TOKEN_X_ADDRESS=0x2AD400c1E8A367Cb77721C9d14Df32F4Adf44212
NEXT_PUBLIC_MOCK_USDC_ADDRESS=0xDf7790C77269Af7FbBe39e30b554b209bA3f22Db
NEXT_PUBLIC_CAUSAL_ORGANIZATIONS_ADDRESS=0xCbFd2C9F46AC9881c145FE11322875d69285c10b

# Uniswap V3 (Fuji - self-deployed 2026-03-09)
NEXT_PUBLIC_UNISWAP_V3_FACTORY=0x6739FCFDC0c6939939C0e8D55188E8D0D973E617
NEXT_PUBLIC_POSITION_MANAGER=0xD7144710B6152526FB33699B166B5917a73f67FE
