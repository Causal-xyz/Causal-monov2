# ===================================
# @causal/web — Next.js Frontend
# ===================================
# Copy this file to .env.local and fill in the values.

# Avalanche Fuji RPC endpoint (public default works, use Infura/Alchemy for production)
NEXT_PUBLIC_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Deployed contract addresses (update after running forge deploy script)
NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_MOCK_TOKEN_X_ADDRESS=
NEXT_PUBLIC_MOCK_USDC_ADDRESS=
NEXT_PUBLIC_CAUSAL_ORGANIZATIONS_ADDRESS=

# Uniswap V3 addresses on Fuji (self-deployed)
NEXT_PUBLIC_UNISWAP_V3_FACTORY=
NEXT_PUBLIC_POSITION_MANAGER=
NEXT_PUBLIC_SWAP_ROUTER=

# WalletConnect project ID (optional — for WalletConnect support)
# Get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
