# Copy this file to .env.local and fill in the values.

# Avalanche Fuji RPC endpoint (public default works, use Infura/Alchemy for production)
NEXT_PUBLIC_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Deployed contract addresses (update after running forge deploy script)
NEXT_PUBLIC_FACTORY_ADDRESS=
NEXT_PUBLIC_MOCK_TOKEN_X_ADDRESS=0xecFa95675aFF2F3776F53853Bb8da5a82015FB51
NEXT_PUBLIC_MOCK_USDC_ADDRESS=0xbeA10d851aD86B86a277aC046C24Eb989dfd027c
NEXT_PUBLIC_CAUSAL_ORGANIZATIONS_ADDRESS=0xFF2f657C62Fa4167EFf334F7d48Ff2aA6C49Bc2B

# Uniswap V3 (Fuji - self-deployed 2026-03-09)
NEXT_PUBLIC_UNISWAP_V3_FACTORY=0x6739FCFDC0c6939939C0e8D55188E8D0D973E617
NEXT_PUBLIC_POSITION_MANAGER=0xD7144710B6152526FB33699B166B5917a73f67FE
NEXT_PUBLIC_SWAP_ROUTER=0x701067e5f83d71975988BE412Bbd922D806fd29D

# WalletConnect project ID (optional — for WalletConnect support)
# Get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
