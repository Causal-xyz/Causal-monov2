# ===================================
# @causal/contracts — Foundry
# ===================================
# Copy this file to .env and fill in the values.

# Deployer private key (WITHOUT 0x prefix)
# WARNING: Never commit this file with a real private key
PRIVATE_KEY=

# Avalanche Fuji RPC
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Snowtrace API key (for contract verification)
SNOWTRACE_API_KEY=

# Etherscan-style verification (Snowtrace uses same format)
ETHERSCAN_API_KEY=
